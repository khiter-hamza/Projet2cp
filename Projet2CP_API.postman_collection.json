{
  "info": {
    "_postman_id": "projet2cp-api-workflow",
    "name": "Projet 2CP - Complete API Workflow",
    "description": "Complete collection for testing the Projet 2CP API workflow including authentication, applications, documents, eligibility, and CS operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register Researcher",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"researcher@test.com\",\n  \"username\": \"researcher_user\",\n  \"lastname\": \"Test\",\n  \"password\": \"TestPassword123!\",\n  \"role\": \"chercheur\",\n  \"grade\": \"professeur\",\n  \"anciente\": 5,\n  \"laboratory_name\": \"Lab1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"username\": \"admin_user\",\n  \"lastname\": \"Admin\",\n  \"password\": \"AdminPassword123!\",\n  \"role\": \"admin_dpgr\",\n  \"grade\": \"professeur\",\n  \"anciente\": 10,\n  \"laboratory_name\": \"Admin_Lab\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login Researcher",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('researcher_token', jsonData.access_token);",
                  "    pm.environment.set('researcher_id', jsonData.user_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"researcher@test.com\",\n  \"password\": \"TestPassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('admin_token', jsonData.access_token);",
                  "    pm.environment.set('admin_id', jsonData.user_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"AdminPassword123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Session Management",
      "item": [
        {
          "name": "Get Active Session",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/sessions/active",
              "host": ["{{base_url}}"],
              "path": ["sessions", "active"]
            }
          }
        },
        {
          "name": "Create Session (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('session_id', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"2024-2025 Academic Year\",\n  \"academic_year\": \"2024-2025\",\n  \"start_date\": \"2024-02-15\",\n  \"end_date\": \"2024-06-30\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/sessions/",
              "host": ["{{base_url}}"],
              "path": ["sessions", ""]
            }
          }
        },
        {
          "name": "List Sessions (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/sessions/",
              "host": ["{{base_url}}"],
              "path": ["sessions", ""]
            }
          }
        }
      ]
