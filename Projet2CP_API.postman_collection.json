    {
      "name": "6. History & Tracking",
      "item": [
        {
          "name": "Get Application History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/applications/{{application_id}}/history?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["applications", "{{application_id}}", "history"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Get History Page",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/applications/history?limit=50&offset=0&sort_by=submitted_at&sort_order=desc&session_filter=this",
              "host": ["{{base_url}}"],
              "path": ["applications", "history"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                },
                {
                  "key": "sort_by",
                  "value": "submitted_at"
                },
                {
                  "key": "sort_order",
                  "value": "desc"
                },
                {
                  "key": "session_filter",
                  "value": "this"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "7. CS Workflow (Admin)",
      "item": [
        {
          "name": "Prepare CS Deliberation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/cs/prepare-deliberation/{{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["cs", "prepare-deliberation", "{{session_id}}"]
            }
          }
        },
        {
          "name": "Get CS Dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/cs/dashboard?session_id={{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["cs", "dashboard"],
              "query": [
                {
                  "key": "session_id",
                  "value": "{{session_id}}"
                }
              ]
            }
          }
        },
        {
          "name": "Approve Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/cs/applications/{{application_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["cs", "applications", "{{application_id}}", "approve"]
            }
          }
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Insufficient research background\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/cs/applications/{{application_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["cs", "applications", "{{application_id}}", "reject"]
            }
          }
        },
        {
          "name": "Get CS Decision History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/cs/decision-history?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["cs", "decision-history"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        }
      ]
