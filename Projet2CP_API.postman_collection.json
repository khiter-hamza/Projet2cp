    {
      "name": "3. Applications",
      "item": [
        {
          "name": "Create Draft Application",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('application_id', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination_country\": \"france\",\n  \"destination_city\": \"Paris\",\n  \"host_institution\": \"University of Paris\",\n  \"scientific_objective\": \"Research on AI and machine learning\",\n  \"start_date\": \"2024-02-20\",\n  \"end_date\": \"2024-03-20\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/applications/",
              "host": ["{{base_url}}"],
              "path": ["applications", ""]
            }
          }
        },
        {
          "name": "Get Application",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/applications/{{application_id}}",
              "host": ["{{base_url}}"],
              "path": ["applications", "{{application_id}}"]
            }
          }
        },
        {
          "name": "List Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/applications/",
              "host": ["{{base_url}}"],
              "path": ["applications", ""]
            }
          }
        },
        {
          "name": "Update Draft Application",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination_country\": \"france\",\n  \"destination_city\": \"Lyon\",\n  \"host_institution\": \"Claude Bernard University\",\n  \"scientific_objective\": \"Advanced research on distributed systems and AI\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/applications/{{application_id}}",
              "host": ["{{base_url}}"],
              "path": ["applications", "{{application_id}}"]
            }
          }
        },
        {
          "name": "Submit Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination_country\": \"france\",\n  \"destination_city\": \"Lyon\",\n  \"host_institution\": \"Claude Bernard University\",\n  \"scientific_objective\": \"Advanced research on distributed systems and AI\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/applications/{{application_id}}/submit",
              "host": ["{{base_url}}"],
              "path": ["applications", "{{application_id}}", "submit"]
            }
          }
        },
        {
          "name": "Cancel Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Visa refused by the host country\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/applications/{{application_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["applications", "{{application_id}}", "cancel"]
            }
          }
        },
        {
          "name": "Delete Draft Application",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/applications/{{application_id}}",
              "host": ["{{base_url}}"],
              "path": ["applications", "{{application_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Documents",
      "item": [
        {
          "name": "Upload Document",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('document_id', jsonData.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "disabled": false
                },
                {
                  "key": "document_type",
                  "value": "cv",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/applications/{{application_id}}/documents",
              "host": ["{{base_url}}"],
              "path": ["applications", "{{application_id}}", "documents"]
            }
          }
        },
        {
          "name": "Get Documents",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/applications/{{application_id}}/documments",
              "host": ["{{base_url}}"],
              "path": ["applications", "{{application_id}}", "documments"]
            }
          }
        },
        {
          "name": "Delete Document",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{researcher_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/document/{{document_id}}",
              "host": ["{{base_url}}"],
              "path": ["document", "{{document_id}}"]
            }
          }
        }
